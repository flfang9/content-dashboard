# ─── Notion (required) ────────────────────────────────────────────────────────
# Get from: notion.so/my-integrations
NOTION_TOKEN=secret_xxxxx

# Get from your database URL: notion.so/DATABASE_ID?v=...
NOTION_DATABASE_ID=your-database-id

# ─── TikTok (no API needed) ───────────────────────────────────────────────────
# Just your username, without the @ symbol
# Example: if your profile is tiktok.com/@buildwithfreddy, use: buildwithfreddy
TIKTOK_USERNAME=your-username

# ─── Instagram (optional) ─────────────────────────────────────────────────────
# Only needed if you want Instagram metrics
# Requires: Business/Creator account + Facebook Page + Meta Developer App
# Leave blank to skip Instagram
IG_USER_ID=
IG_ACCESS_TOKEN=

# ─── Growth Tracking (optional) ───────────────────────────────────────────────
# For daily follower snapshots, run: node scripts/setup-growth-db.js
# This creates a Growth History database with:
# - Date, TikTok Followers, TikTok Total Likes, TikTok Videos
# - Instagram Followers, Instagram Posts
# - TikTok Views, TikTok Likes, Instagram Views, Instagram Likes
NOTION_GROWTH_DATABASE_ID=
