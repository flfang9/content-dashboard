# ─── Notion ───────────────────────────────────────────────────────────────────
NOTION_TOKEN=secret_xxxxx
NOTION_DATABASE_ID=your-database-id

# ─── Instagram (optional) ─────────────────────────────────────────────────────
# Requires: Instagram Business or Creator account connected to a Facebook Page
IG_USER_ID=
IG_ACCESS_TOKEN=

# ─── TikTok ───────────────────────────────────────────────────────────────────
# Your TikTok username (for follower tracking)
TIKTOK_USERNAME=your-username

# ─── Growth Tracking (optional) ───────────────────────────────────────────────
# Create a separate Notion database with: Date, TikTok Followers, TikTok Likes, TikTok Videos
# NOTION_GROWTH_DATABASE_ID=
