# Notion Integration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=your-notion-database-id

# Growth Tracking Database (run: node scripts/setup-growth-db.js to create)
NOTION_GROWTH_DATABASE_ID=your-growth-database-id

# Cron job protection
CRON_SECRET=your-random-secret-string

# Instagram Graph API (required for IG metrics and follower tracking)
META_ACCESS_TOKEN=your-meta-access-token
IG_USER_ID=your-instagram-user-id

# TikTok (for follower tracking)
TIKTOK_USERNAME=your-tiktok-username
TIKTOK_SESSION_ID=optional-for-private-metrics
